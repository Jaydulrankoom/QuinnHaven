              "id": "vrngh5k",
              "settings": {
                "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>QuinnHaven Contact Page</title>\n  \n  <!-- Fonts: Inter for UI & Playfair Display for Serif -->\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap\" rel=\"stylesheet\">\n  \n  <!-- Tailwind CSS via CDN for easy elementor mapping -->\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  \n  <style>\n    body {\n      margin: 0;\n      font-family: 'Inter', sans-serif;\n      /* Cream background */\n      background-color: #f5f2ed;\n    }\n    .font-serif {\n      font-family: 'Playfair Display', serif;\n    }\n    .font-sans {\n      font-family: 'Inter', sans-serif;\n    }\n  </style>\n</head>\n<body>\n\n  <!-- CONTACT PAGE WRAPPER -->\n  <div class=\"flex flex-col min-h-screen pt-32 pb-24\" style=\"background-color: #f5f2ed;\">\n    <div class=\"max-w-7xl mx-auto px-6 lg:px-8 w-full flex flex-col lg:flex-row gap-16 xl:gap-24\">\n      \n      <!-- INFO COLUMN -->\n      <div class=\"lg:w-1/3\">\n         <span class=\"uppercase tracking-[0.3em] text-xs font-bold mb-6 block\" style=\"color: #B8995E;\">Get in Touch</span>\n         <h1 class=\"text-5xl lg:text-6xl font-serif mb-8\" style=\"color: #1a1a1a;\">Design<br/>Consultation</h1>\n         <p class=\"font-light leading-relaxed mb-12 text-lg\" style=\"color: rgba(26, 26, 26, 0.7);\">\n           Ready to transform your home? Fill out the form to schedule a complimentary design consultation at our showroom or via video call.\n         </p>\n\n         <div class=\"space-y-8 border-t pt-12\" style=\"border-color: rgba(26, 26, 26, 0.1);\">\n           <div>\n             <h4 class=\"font-serif text-2xl mb-3\" style=\"color: #1a1a1a;\">General Inquiries</h4>\n             <p class=\"font-light text-lg transition-colors hover:text-[#B8995E]\" style=\"color: rgba(26, 26, 26, 0.8);\">\n                <a href=\"mailto:info@quinnhavendesign.com\">info@quinnhavendesign.com</a>\n             </p>\n             <p class=\"font-light text-lg transition-colors hover:text-[#B8995E]\" style=\"color: rgba(26, 26, 26, 0.8);\">\n                <a href=\"tel:+18609180388\">+1 (860) 918-0388</a>\n             </p>\n           </div>\n           <div>\n             <h4 class=\"font-serif text-2xl mb-3\" style=\"color: #1a1a1a;\">Showroom</h4>\n             <p class=\"font-light text-lg leading-relaxed\" style=\"color: rgba(26, 26, 26, 0.8);\">\n                121 N Plains Industrial Road, Unit C, Wallingford, CT, United States\n             </p>\n           </div>\n         </div>\n\n         <!-- Trust / Privacy Box -->\n         <div class=\"mt-12 bg-white border p-6 flex items-start gap-4 shadow-sm\" style=\"border-color: rgba(26, 26, 26, 0.1);\">\n            <!-- Inline SVG replacing the Lucide ShieldCheck Icon -->\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#B8995E\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"shrink-0\">\n               <path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"></path>\n               <path d=\"m9 12 2 2 4-4\"></path>\n            </svg>\n            <div>\n               <h5 class=\"font-serif text-lg font-semibold mb-1\" style=\"color: #1a1a1a;\">Privacy Assured</h5>\n               <p class=\"text-xs font-light leading-relaxed\" style=\"color: rgba(26, 26, 26, 0.6);\">Your information is kept strictly confidential. We never share your details with third parties.</p>\n            </div>\n         </div>\n      </div>\n\n      <!-- FORM COLUMN -->\n      <div class=\"lg:w-2/3 bg-white p-10 md:p-16 border shadow-2xl relative\" style=\"border-color: rgba(26, 26, 26, 0.05);\">\n         <!-- Top Gold Accent Bar -->\n         <div class=\"absolute top-0 left-0 w-full h-[4px]\" style=\"background-color: #B8995E;\"></div>\n         \n         <h3 class=\"font-serif text-3xl mb-10\" style=\"color: #1a1a1a;\">Project Details</h3>\n         \n         <form class=\"space-y-8\" action=\"#\" method=\"POST\">\n           \n           <div class=\"grid grid-cols-1 md:grid-cols-2 gap-8\">\n              <div>\n                <label class=\"block text-xs uppercase tracking-widest font-bold mb-2\" style=\"color: rgba(26, 26, 26, 0.6);\">First Name</label>\n                <input type=\"text\" class=\"w-full border-b bg-transparent py-3 focus:outline-none transition-colors border-b-gray-300 focus:border-b-[#B8995E]\" style=\"color: #1a1a1a;\" required />\n              </div>\n              <div>\n                <label class=\"block text-xs uppercase tracking-widest font-bold mb-2\" style=\"color: rgba(26, 26, 26, 0.6);\">Last Name</label>\n                <input type=\"text\" class=\"w-full border-b bg-transparent py-3 focus:outline-none transition-colors border-b-gray-300 focus:border-b-[#B8995E]\" style=\"color: #1a1a1a;\" required />\n              </div>\n           </div>\n           \n           <div class=\"grid grid-cols-1 md:grid-cols-2 gap-8\">\n              <div>\n                <label class=\"block text-xs uppercase tracking-widest font-bold mb-2\" style=\"color: rgba(26, 26, 26, 0.6);\">Email Address</label>\n                <input type=\"email\" class=\"w-full border-b bg-transparent py-3 focus:outline-none transition-colors border-b-gray-300 focus:border-b-[#B8995E]\" style=\"color: #1a1a1a;\" required />\n              </div>\n              <div>\n                <label class=\"block text-xs uppercase tracking-widest font-bold mb-2\" style=\"color: rgba(26, 26, 26, 0.6);\">Phone Number</label>\n                <input type=\"tel\" class=\"w-full border-b bg-transparent py-3 focus:outline-none transition-colors border-b-gray-300 focus:border-b-[#B8995E]\" style=\"color: #1a1a1a;\" />\n              </div>\n           </div>\n\n           <div>\n              <label class=\"block text-xs uppercase tracking-widest font-bold mb-2\" style=\"color: rgba(26, 26, 26, 0.6);\">Project Type</label>\n              <div class=\"relative\">\n                <select class=\"w-full border-b bg-transparent py-3 focus:outline-none transition-colors appearance-none border-b-gray-300 focus:border-b-[#B8995E]\" style=\"color: #1a1a1a;\">\n                  <option value=\"\">Select an option</option>\n                  <option value=\"kitchen\">Kitchen Remodel</option>\n                  <option value=\"bathroom\">Bathroom Remodel</option>\n                  <option value=\"cabinets\">Custom Cabinetry</option>\n                  <option value=\"closet\">Closet Design</option>\n                  <option value=\"other\">Other / Multiple Rooms</option>\n                </select>\n                <!-- Inline SVG Down Arrow -->\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"rgba(26,26,26,0.3)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"absolute right-2 top-1/2 -translate-y-1/2 pointer-events-none\">\n                   <path d=\"m6 9 6 6 6-6\"></path>\n                </svg>\n              </div>\n           </div>\n\n           <div>\n              <label class=\"block text-xs uppercase tracking-widest font-bold mb-2\" style=\"color: rgba(26, 26, 26, 0.6);\">Message & Budget Details</label>\n              <textarea rows=\"5\" class=\"w-full border-b bg-transparent py-3 focus:outline-none transition-colors resize-none border-b-gray-300 focus:border-b-[#B8995E]\" style=\"color: #1a1a1a;\"></textarea>\n           </div>\n\n           <button type=\"submit\" class=\"w-full text-white py-5 uppercase tracking-widest text-sm font-bold transition-colors mt-8 shadow-lg font-sans\" style=\"background-color: #1a1a1a;\" onmouseover=\"this.style.backgroundColor='#B8995E'\" onmouseout=\"this.style.backgroundColor='#1a1a1a'\">\n             Submit Request\n           </button>\n         </form>\n      </div>\n\n    </div>\n  </div>\n\n</body>\n</html>\n"
              },
