                "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>QuinnHaven Hero Section</title>\n  \n  <!-- Fonts: Inter for UI & Playfair Display for Serif -->\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap\" rel=\"stylesheet\">\n  \n  <!-- Tailwind CSS via CDN for easy elementor mapping -->\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  \n  <!-- Framer Motion functionality mapped to vanilla JS/CSS for standalone HTML -->\n  <style>\n    :root {\n      --color-charcoal: #1a1a1a;\n      --color-charcoal-light: #2c2c2c;\n      --color-gold: #B8995E;\n      --color-gold-light: #d4b881;\n      --color-brand: #141162;\n    }\n\n    body {\n      margin: 0;\n      font-family: 'Inter', sans-serif;\n      background-color: var(--color-charcoal);\n    }\n\n    .font-serif {\n      font-family: 'Playfair Display', serif;\n    }\n\n    /* Hero Parallax Animations */\n    @keyframes float1 {\n      0%, 100% { transform: translateY(0); }\n      50% { transform: translateY(-15px); }\n    }\n\n    @keyframes float2 {\n      0%, 100% { transform: translateY(0); }\n      50% { transform: translateY(15px); }\n    }\n\n    /* Initial Load Animations */\n    @keyframes slideInUp {\n      from { opacity: 0; transform: translateY(30px); }\n      to { opacity: 1; transform: translateY(0); }\n    }\n    \n    @keyframes slideInLeft1 {\n       from { opacity: 0; transform: translateX(50px) translateY(20px); }\n      to { opacity: 1; transform: translateX(0) translateY(0); }\n    }\n\n    @keyframes slideInLeft2 {\n      from { opacity: 0; transform: translateX(30px) translateY(50px); }\n      to { opacity: 1; transform: translateX(0) translateY(0); }\n    }\n\n    .hero-content {\n      animation: slideInUp 1s ease-out forwards;\n    }\n\n    /* Floating Image 1 Setup */\n    .floating-img-1-container {\n      animation: slideInLeft1 1.5s ease-out 0.2s both; /* Entrance */\n    }\n    .floating-img-1 {\n      animation: float1 6s ease-in-out 1.7s infinite; /* Continuous loop */\n    }\n\n    /* Floating Image 2 Setup */\n    .floating-img-2-container {\n      animation: slideInLeft2 1.5s ease-out 0.5s both; /* Entrance */\n    }\n    .floating-img-2 {\n      animation: float2 8s ease-in-out 2s infinite; /* Continuous loop */\n    }\n  </style>\n</head>\n<body>\n\n  <!-- LAYERED 3D HERO SECTION -->\n  <section class=\"relative h-screen min-h-[800px] w-full overflow-hidden bg-[#1a1a1a] flex items-center\">\n    \n    <!-- Background Base -->\n    <div \n      class=\"absolute inset-0 bg-[url('https://images.unsplash.com/photo-1556912173-3bb406ef7e77?q=80&w=2070&auto=format&fit=crop')] bg-cover bg-center opacity-40 scale-105\"\n      style=\"transform: translateZ(0)\"\n    ></div>\n    \n    <!-- Subtle Brand & Charcoal Gradient Overlay -->\n    <div class=\"absolute inset-0 mix-blend-multiply\" style=\"background: linear-gradient(to right, rgba(20, 17, 98, 0.9), rgba(26, 26, 26, 0.8), rgba(20, 17, 98, 0.2));\"></div>\n    <div class=\"absolute inset-0 opacity-90\" style=\"background: linear-gradient(to top, #1a1a1a, transparent, transparent);\"></div>\n\n    <!-- Floating 3D Elements (Parallax & Continuous Animation) -->\n    <!-- Image 1 -->\n    <div class=\"hidden lg:block absolute right-[-5%] top-[15%] w-[40vw] h-[55vh] z-0 floating-img-1-container\">\n        <div class=\"w-full h-full rounded-2xl overflow-hidden border border-white/5 floating-img-1\" style=\"box-shadow: 0 30px 60px rgba(20, 17, 98, 0.4);\">\n            <div class=\"absolute inset-0 bg-[#141162]/10 mix-blend-overlay z-10 w-full h-full\"></div>\n            <img \n              src=\"https://images.unsplash.com/photo-1600585154340-be6161a56a0c?q=80&w=2070&auto=format&fit=crop\" \n              alt=\"Luxury Kitchen Preview\" \n              class=\"w-full h-full object-cover\"\n            />\n        </div>\n    </div>\n\n    <!-- Image 2 -->\n    <div class=\"hidden lg:block absolute right-[25%] bottom-[10%] w-[25vw] h-[35vh] z-0 floating-img-2-container\">\n        <div class=\"w-full h-full rounded-2xl overflow-hidden border border-white/10 floating-img-2\" style=\"box-shadow: 0 20px 40px rgba(20, 17, 98, 0.5);\">\n            <div class=\"absolute inset-0 bg-[#141162]/20 mix-blend-overlay z-10 w-full h-full\"></div>\n            <img \n              src=\"https://images.unsplash.com/photo-1620626011761-996317b8d101?q=80&w=2069&auto=format&fit=crop\" \n              alt=\"Material Details\" \n              class=\"w-full h-full object-cover\"\n            />\n        </div>\n    </div>\n\n    <!-- Content Box -->\n    <div class=\"relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-8 mt-16 hero-content\">\n      <div class=\"max-w-2xl\">\n        <div class=\"flex items-center gap-4 mb-6\">\n          <div class=\"h-[1px] w-12 bg-[#B8995E]\"></div>\n          <span class=\"text-[#B8995E] uppercase tracking-[0.3em] text-xs font-semibold\">\n            Kitchen Cabinets & Bathroom Design\n          </span>\n        </div>\n        \n        <h1 class=\"text-5xl md:text-7xl font-serif text-white leading-[1.1] mb-8 font-light\">\n          Crafting <span class=\"italic text-[#d4b881]\">Timeless</span> <br />\n          Spaces for Living.\n        </h1>\n        \n        <p class=\"text-lg text-white/80 font-light max-w-lg mb-10 leading-relaxed font-sans\">\n          Experience the pinnacle of luxury cabinetry and design. From master bathrooms to culinary-grade kitchens, we bring your ultimate vision to life.\n        </p>\n        \n        <div class=\"flex flex-col sm:flex-row gap-6\">\n          <a href=\"/contact\" class=\"bg-[#B8995E] text-white px-8 py-4 uppercase tracking-widest text-sm font-medium hover:bg-white hover:text-[#1a1a1a] transition-all duration-300 text-center font-sans\">\n            Book Free Consultation\n          </a>\n          <a href=\"/portfolio\" class=\"border border-white/30 text-white px-8 py-4 uppercase tracking-widest text-sm font-medium hover:bg-white/10 transition-all duration-300 text-center flex items-center justify-center gap-2 font-sans\">\n            Explore Portfolio\n          </a>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- 2. TRUST / EXPERIENCE BAND -->\n  <section class=\"py-12 border-y border-white/5 relative z-10\" style=\"background-color: #2c2c2c;\">\n    <div class=\"max-w-7xl mx-auto px-6 lg:px-8\">\n      <!-- Grid setup using Tailwind layout utilities -->\n      <div class=\"grid grid-cols-2 md:grid-cols-4 gap-8 md:divide-x md:divide-white/10\">\n        \n        <!-- Stat Block 1 -->\n        <div class=\"text-center px-4\">\n          <span class=\"block font-serif text-4xl text-[#B8995E] mb-2\">25+</span>\n          <span class=\"block text-xs uppercase tracking-widest text-white/70 font-sans\">Years Experience</span>\n        </div>\n        \n        <!-- Stat Block 2 -->\n        <div class=\"text-center px-4\">\n          <span class=\"block font-serif text-4xl text-[#B8995E] mb-2\">500+</span>\n          <span class=\"block text-xs uppercase tracking-widest text-white/70 font-sans\">Projects Completed</span>\n        </div>\n        \n        <!-- Stat element 3 -->\n        <div class=\"text-center px-4\">\n          <span class=\"block font-serif text-4xl text-[#B8995E] mb-2\">4</span>\n          <span class=\"block text-xs uppercase tracking-widest text-white/70 font-sans\">Showroom Locations</span>\n        </div>\n        \n        <!-- Stat element 4 -->\n        <div class=\"text-center px-4\">\n          <span class=\"block font-serif text-4xl text-[#B8995E] mb-2\">100%</span>\n          <span class=\"block text-xs uppercase tracking-widest text-white/70 font-sans\">Custom Craftsmanship</span>\n        </div>\n\n      </div>\n    </div>\n  </section>\n\n</body>\n</html>\n"
